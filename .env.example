## Required for local or production app startup
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_system
SITE_URL=https://your-service.onrender.com

## Trial billing default
BILLING_PROVIDER=duitnow_manual
TRIAL_DAYS=14

## Optional Stripe configuration
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_GROWTH=price_xxx

## Optional DuitNow manual billing configuration
DUITNOW_RECIPIENT_NAME=Restaurant OS Sdn Bhd
DUITNOW_ACCOUNT_ID=your-merchant-id
DUITNOW_ACCOUNT_TYPE=Merchant ID
DUITNOW_QR_IMAGE_URL=
DUITNOW_REFERENCE_PREFIX=ROS
DUITNOW_PAYMENT_NOTE=Complete the transfer and confirm it manually in the owner console.
